# ── Bind addresses ────────────────────────────────────────────────
# Backend bind address (0.0.0.0 = all interfaces, 127.0.0.1 = loopback only)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=18000

# Frontend dev server ports (always binds to 0.0.0.0)
STUDENT_PORT=3000
ADMIN_PORT=3001

# ── Internal / reverse-proxy URL mapping ──────────────────────────
# URL the Vite dev server uses to proxy /api requests to the backend.
# Usually matches BACKEND_HOST:BACKEND_PORT; keep localhost for single-machine setups.
BACKEND_PROXY_URL=http://localhost:18000

# Public-facing URLs shown in the start.sh summary (does not affect runtime behavior).
# Change to the actual LAN IP or domain when deploying on an intranet.
BACKEND_PUBLIC_URL=http://localhost:18000
STUDENT_PUBLIC_URL=http://localhost:3000
ADMIN_PUBLIC_URL=http://localhost:3001

# ── Frontend API base URL (production builds) ─────────────────────
# Leave unset in development: the frontend reaches the backend via Vite proxy (/api).
# Set for production builds so the frontend calls the backend directly.
# VITE_API_BASE_URL=http://192.168.1.100:18000/api

# ── AI Provider configuration ─────────────────────────────────────
# Supported: openai, claude, grok, kimi, deepseek, custom
AI_PROVIDER=openai
AI_API_KEY=sk-your-api-key-here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Provider-specific base URLs:
# OpenAI:   https://api.openai.com/v1
# Claude:   https://api.anthropic.com
# Grok:     https://api.x.ai/v1
# Kimi:     https://api.moonshot.cn/v1
# DeepSeek: https://api.deepseek.com/v1
